# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# --- MCP: Brave Search ---
BRAVE_API_KEY=your_brave_api_key_here

# --- MCP: GitHub ---
# Create a PAT at https://github.com/settings/tokens
# Fine-grained: permissions — Contents, Issues, Pull requests, Metadata (Read/Write)
# The MCP server internally uses GITHUB_PERSONAL_ACCESS_TOKEN;
# set GITHUB_TOKEN in your system env and .mcp.json maps it across.
GITHUB_TOKEN=your_github_pat_here

# --- MCP: OpenProject ---
# Your OpenProject instance URL and API key
# Get API key: OpenProject → My Account → Access Tokens → Generate
OPENPROJECT_URL=https://your-instance.openproject.com
OPENPROJECT_API_KEY=your_openproject_api_key_here

# --- MCP: DuckDB / MotherDuck ---
# Leave empty to use local DuckDB only (no MotherDuck cloud needed)
# Set to your MotherDuck token to also query cloud databases
MOTHERDUCK_TOKEN=

# --- MCP: Jupyter ---
# URL of running Jupyter server (start with: jupyter lab --no-browser)
JUPYTER_BASE_URL=http://localhost:8888
JUPYTER_TOKEN=123456

# --- Fintech / Market Data ---
# Uncomment and fill in whichever you use:
# POLYGON_API_KEY=
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
# ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Cheminformatics ---
# ChEMBL API (no key required for public endpoints, but rate-limit token helps)
# CHEMBL_CACHE_BACKEND=django_redis
# Schrödinger license (if using Maestro/Glide)
# SCHRODINGER=

# --- Database (if using PostgreSQL MCP) ---
# DATABASE_URL=postgresql://user:password@localhost:5432/mlproject

# --- Experiment tracking ---
# MLFLOW_TRACKING_URI=http://localhost:5000
# WANDB_API_KEY=
